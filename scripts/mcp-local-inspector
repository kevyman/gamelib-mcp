#!/usr/bin/env bash
set -euo pipefail

SERVER_URL="${MCP_SERVER_URL:-http://127.0.0.1:8000/sse}"
TRANSPORT="${MCP_TRANSPORT:-sse}"

args=(
  --cli
  "$SERVER_URL"
  --transport "$TRANSPORT"
)

if [[ -n "${MCP_AUTH_TOKEN:-}" ]]; then
  args+=(--header "Authorization: Bearer ${MCP_AUTH_TOKEN}")
fi

exec mcp-inspector "${args[@]}" "$@"
