# Copy this file to `.env` for local Docker testing.

# Core runtime
DATABASE_URL=file:/data/gamelib.db
PORT=8000
MCP_AUTH_TOKEN=

# Steam-specific sync and review integration
STEAM_API_KEY=
STEAM_ID=
STEAM_PROFILE_ID=

# Optional integrations
BACKLOGGD_USER=
PSN_NPSSO=
NINTENDO_SESSION_TOKEN=
NINTENDO_COOKIES_FILE=/data/nintendo_cookies.json
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Optional host-mounted config paths used by docker-compose.yml
EPIC_LEGENDARY_HOST_PATH=./data/legendary
LGOGDOWNLOADER_HOST_PATH=./data/lgogdownloader
