DATABASE_URL=file:/data/gamelib.db
MCP_AUTH_TOKEN=change-me-generate-with-openssl-rand-hex-32
PORT=8000
# Control plane inspects both values. Missing either keeps Steam unconfigured/readiness red.
STEAM_API_KEY=your-key-from-steamcommunity.com/dev/apikey
STEAM_ID=your-64bit-steamid
# IGDB (Twitch) credentials — for game identity resolution and metadata enrichment
# Get from https://dev.twitch.tv/console (create an application, category = Website Integration)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
STEAM_PROFILE_ID=your-steam-community-profile-id
BACKLOGGD_USER=your-backloggd-username
# Control plane inspects the mounted Legendary dir for `user.json` and `metadata/*.json`.
# Missing either leaves Epic unconfigured/partial; stale auth from startup sync shows as degraded.
EPIC_LEGENDARY_HOST_PATH=   # host path to legendary config dir; defaults to ./data/legendary
# Control plane inspects this mount and whether `lgogdownloader` exists in PATH inside the container.
LGOGDOWNLOADER_HOST_PATH=   # host path to lgogdownloader config dir; defaults to ./data/lgogdownloader
# Control plane inspects this for Nintendo nxapi readiness; expired auth may surface as stale after sync.
NINTENDO_SESSION_TOKEN=     # from: nxapi nso auth
# Control plane inspects this binary path if set; missing binary leaves Nintendo degraded when using nxapi.
NXAPI_BIN=nxapi             # optional: path to nxapi binary if not in PATH
# Control plane inspects this fallback cookie file for Nintendo ownership-only VGCS readiness.
NINTENDO_COOKIES_FILE=data/nintendo_cookies.json  # use set_nintendo_session to populate; no secret values are echoed back
# Control plane inspects whether this value is set; expired auth may surface as stale after sync.
PSN_NPSSO=   # NPSSO cookie from https://ca.account.sony.com/api/v1/ssocookie

# Hardware preference for get_recommendations suggested_platform (comma-separated, highest priority first)
# Stored in the meta table via: INSERT OR REPLACE INTO meta VALUES ('hardware_preference', '["switch2","steam_deck","ps5"]')
HARDWARE_PREFERENCE=switch2,steam_deck,ps5
